# ============================================================
# Pardus Lock System - Ortam Değişkenleri Örneği
# Bu dosyayı kopyalayıp .env olarak yeniden adlandırın:
#   cp .env.example .env
# Ardından değerleri kendi ortamınıza göre doldurun.
# ============================================================

# -------------------------------------------------------
# Sunucu Adresi
# İstemci uygulamalarının bağlanacağı Flask API adresi.
# Örnek: http://192.168.1.100:5000  veya  https://yourdomain.com
# -------------------------------------------------------
VDS_URL=http://YOUR_SERVER_IP:5000

# -------------------------------------------------------
# Web Arayüzü Baz URL'i
# Kurulum script endpoint'inin kullandığı web adres.
# -------------------------------------------------------
WEB_BASE_URL=http://YOUR_SERVER_IP:4234

# -------------------------------------------------------
# Admin Şifreleri (İlk Kurulumda Otomatik Oluşturulur)
# Boş bırakılırsa sunucu rastgele şifre üretir ve loglar.
# -------------------------------------------------------
DEFAULT_ADMIN_PASSWORD=
DEFAULT_SA_PASSWORD=

# -------------------------------------------------------
# İletişim Formu (Opsiyonel)
# Web sitesindeki iletişim formundan gelen mesajlar
# bu Gmail hesabı üzerinden iletilir.
# Kullanmayacaksanız boş bırakın.
# -------------------------------------------------------
CONTACT_EMAIL=your-contact@example.com
CONTACT_PASSWORD=your-gmail-app-password
